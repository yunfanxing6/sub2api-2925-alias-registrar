# Compatibility tempmail service example.
# This file still matches sub2api-browser-domain-registrar.service, but it starts the tempmail script.
SUB2API_URL=http://127.0.0.1:8080
SUB2API_ADMIN_API_KEY=replace_me
MAIL_SOURCES=tempmail_lol,mailtm,onesecmail
DUCKMAIL_KEY=
GROUP_IDS=all
CONCURRENCY=10
PRIORITY=1
COUNT=1
MAX_ATTEMPTS=1
RETRY_SLEEP=1
SLEEP_SECONDS=0
LOOP=1
HEADLESS=0
DEBUG=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_CACHE_FILE=/root/sub2api-2925-alias-registrar/telegram_chat_id.txt
PROXY=
SUB2API_PROXY_ID=
REDIRECT_URI=http://localhost:1455/auth/callback
ARTIFACTS_DIR=/root/sub2api-2925-alias-registrar/browser_artifacts
HISTORY_FILE=/root/sub2api-2925-alias-registrar/tempmail_history_service.jsonl
